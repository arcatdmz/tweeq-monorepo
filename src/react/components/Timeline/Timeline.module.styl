.tqTimeline
	position relative
	display grid
	grid-template-rows 1fr var(--tq-scrollbar-width) 2px
	overflow hidden

.container
	position relative
	overflow hidden
	width 100%
	height 100%

.fixed
	position absolute
	inset 0

.scrollbar
	position relative

.knob
	position absolute
	height 100%
	border-radius 9999px
	background 'color-mix(in srgb, var(--tq-color-text) 20%, transparent)' % ''
