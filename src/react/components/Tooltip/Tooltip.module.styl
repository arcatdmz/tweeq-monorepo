@import '../../../common.styl'

.tqTooltip
	padding .2em .5em
	border-radius 9999px
	border 1px solid var(--tq-color-border)
	background var(--tq-color-surface)
	color var(--tq-color-text)
	backdrop-filter blur(var(--tq-popup-blur))
	font-size .9em
	font-numeric()

	label
		color var(--tq-color-text-mute)
