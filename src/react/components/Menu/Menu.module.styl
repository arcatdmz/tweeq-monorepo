@import '../../../common.styl'

.tqMenu
	display flex
	flex-direction column
	popup-style()
	display grid
	grid-template-columns min-content 1fr

.separator
	grid-column 1 / 3
	height 1px
	margin 3px 6px
	background var(--tq-color-border)

.menu
	grid-column 1 / 3
	display grid
	grid-template-columns subgrid
	padding 2px 6px
	height calc(var(--tq-input-height) + 4px)
	line-height var(--tq-input-height)
	align-items center
	border-radius var(--tq-radius-input)

.submenuOpen
	background var(--tq-color-neutral)

.active
	background var(--tq-color-accent)
	color var(--tq-color-on-accent)

.icon
	margin-right 8px

.labelContainer
	display flex
	justify-content center
	align-items center

.label
	flex-grow 1
	margin-right 1em

.bindIcon
	opacity .5

.groupChevron
	margin-right -6px
