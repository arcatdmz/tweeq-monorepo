@import '../../../common.styl'

.popup
	position fixed
	inset auto
	popup-style()
	margin 3px 0
	z-index 1000
	visibility hidden
	padding 0
	border-color var(--tq-color-accent)
	box-shadow none
	overflow hidden
	box-sizing border-box

	&:not(:hover)
		width var(--tq-icon-size)
		height var(--tq-icon-size)
		border-radius 99px

	&.visible
		visibility visible

.tuneIcon
	position absolute
	top -1px
	left -1px
	width var(--tq-icon-size)
	height var(--tq-icon-size)
	scale .8
	color var(--tq-color-accent)
	pointer-events none

.actions
	display flex
	padding 2px
	gap var(--tq-gap-group)
	opacity 0

	.popup:hover &
		opacity 1

.pad, .button
	border-radius var(--tq-radius-input)

	&:hover
		background var(--tq-color-input-hover)

.slider
	cursor ew-resize

.pad2d
	cursor move
