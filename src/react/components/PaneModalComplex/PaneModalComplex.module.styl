@import '../../../common.styl'

.modalComplex
	display flex
	flex-direction column
	gap var(--tq-gap-section)
	min-height 0

.body
	flex 1 1 auto
	min-height 0
	overflow-y auto
	margin-right calc(-1 * var(--tq-pane-padding))
	padding-right var(--tq-pane-padding)
	scroll-fade-mask()

.footer
	flex 0 0 auto
	display flex
	gap var(--tq-gap-control)

	> *
		flex 1
