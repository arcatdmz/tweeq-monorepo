@import '../../../common.styl'

.tqInputTime
	position relative
	overflow visible !important

.digits
	z-index 100
	position absolute
	inset 0
	display flex
	align-items center
	justify-content center
	flex-direction row-reverse

.digitGroup
	display contents

.digit, .tweak
	position relative
	padding .1em .2em
	border-radius var(--tq-radius-input)

.tqInputTime:hover .tweak
	background set-alpha(--tq-color-text-subtle, .3)

.digitLabel
	position absolute
	z-index 1
	bottom calc(100% + .6em)
	left 50%
	transform translate(-50%, 0)

.separator
	padding .1em 0
	font-weight bold
	color var(--tq-color-text-mute)

.overlay
	input-overlay()
	position absolute
	inset auto
	width 360px
	height 360px
	translate -50% -50%
	mask radial-gradient(closest-side, transparent 0%, black 50%)

.overlay > .overlaySvg
	// input-overlay() sizes descendant SVGs to the viewport. This wheel is a
	// local 100×100 viewBox and must override that more-specific shared rule.
	position absolute
	inset 0
	overflow visible
	width 360px
	height 360px

	path
		stroke var(--tq-color-text-subtle)
		vector-effect non-scaling-stroke
		fill none

.frame
	stroke-width 10
	stroke var(--tq-color-border)

.second
	stroke-width 1

.minute
	stroke-width 3

.hour
	stroke-width 5

.activeTick
	stroke var(--tq-color-accent) !important
