@import '../../../common.styl'

circle-handle()
	position absolute
	margin-bottom calc(-.35 * var(--tq-input-height))
	margin-left calc(-.35 * var(--tq-input-height))
	width calc(.7 * var(--tq-input-height))
	height calc(.7 * var(--tq-input-height))
	border-radius 50%
	box-shadow 0 0 0 1.5px #fff, inset 0 0 0 1px rgba(0, 0, 0, .2), 0 0 1px 2px rgba(0, 0, 0, .4)
	active-transition(transform)

	&:hover
		box-shadow 0 0 0 2px #fff, inset 0 0 0 1px rgba(0, 0, 0, .2), 0 0 1px 3px rgba(0, 0, 0, .4)

background-checkerboard(color = currentColor)
	size = 6px
	background-color white
	background-image linear-gradient(to right, color, color), linear-gradient(45deg, #ddd 25%, transparent 25%), linear-gradient(135deg, #ddd 25%, transparent 25%), linear-gradient(45deg, transparent 75%, #ddd 75%), linear-gradient(135deg, transparent 75%, #ddd 75%)
	background-position 0 0, 0 0, size 0, size (-1 * size), 0 size
	background-size 2 * size 2 * size
