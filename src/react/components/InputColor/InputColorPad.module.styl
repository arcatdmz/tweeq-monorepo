@import './common.styl'

.padButton
	width fit-content
	position relative
	display flex
	padding 0

.defaultButton
	position relative
	overflow hidden
	border-radius var(--tq-radius-input)
	width var(--tq-input-height)
	height var(--tq-input-height)
	hover-transition(box-shadow)
	background-checkerboard()
	use-input-position()
	box-shadow inset 0 0 0 1px var(--outline)

	.padButton:focus &, .focus &, &:hover, &.tweaking
		--outline var(--tq-color-accent) !important
		box-shadow 0 0 0 1px var(--outline)

.floating
	width var(--tq-popup-width)
	max-height calc(100dvh - 16px)
	overflow-y auto
	position relative
	popup-style()

.overlay
	input-overlay()
	opacity 1

.overlayPad, .wheel, .overlaySlider
	position fixed
	border-radius var(--tq-radius-input)
	width var(--tq-popup-width)
	overflow hidden
	active-transition(opacity)

.overlayPad
	position absolute
	aspect-ratio 1
	mask linear-gradient(to right, black 4px, transparent 4px, transparent calc(100% - 4px), black calc(100% - 4px)) 0 0, linear-gradient(to bottom, black 4px, transparent 4px, transparent calc(100% - 4px), black calc(100% - 4px)) 0 0

.wheel
	aspect-ratio 1
	border-radius 50%
	margin-left calc(var(--tq-popup-width) / -2)
	margin-top -4px
	mask radial-gradient(closest-side, transparent calc(100% - 4.5px), black calc(100% - 4px))

.overlaySlider
	height calc(.5 * var(--tq-input-height))
	transform translate(-50%, -50%)
	color transparent
	background-checkerboard()

.verticalSlider
	transform translate(-50%, -50%) rotate(-90deg)

.tweakPreview
	position absolute
	overflow hidden
	width var(--tq-input-height)
	height var(--tq-input-height)
	margin calc(var(--tq-input-height) / -2) 0 0 calc(var(--tq-input-height) / -2)
	pointer-events none
	transform scale(1.8)
	border-radius calc(var(--tq-input-height) / 2)
	background-checkerboard()
	box-shadow 0 0 1px 0 var(--tq-color-shadow)

.overlayLabel
	position absolute
	transform translate(-50%, calc(-100% - var(--tq-input-height) * 1.7))
	display flex
	gap 1em
	white-space nowrap

.labelValue
	display inline-block
	width 3.7em
	text-align right
	color var(--tq-color-text)

	&[data-rgb]
		width 2.2em
