{
	"name": "tweeq",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.12.0",
	"scripts": {
		"dev": "pnpm --filter @tweeq/docs dev",
		"dev:demo": "pnpm --filter @tweeq/docs dev",
		"build": "pnpm -r --if-present build",
		"build:demo": "pnpm --filter @tweeq/docs build",
		"e2e": "LD_LIBRARY_PATH=$HOME/.cache/ms-playwright/local-libs playwright test",
		"lint": "eslint packages apps/docs e2e",
		"test": "pnpm -r --if-present test",
		"check:boundaries": "node scripts/check-boundaries.mjs",
		"test:packed": "node scripts/test-packed.mjs"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@eslint/js": "^9.21.0",
		"@playwright/test": "^1.61.1",
		"eslint": "^9.21.0",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"eslint-plugin-unused-imports": "^4.1.4",
		"globals": "^17.7.0",
		"typescript": "^5.5.3",
		"typescript-eslint": "^8.25.0"
	}
}
