{
	"name": "tweeq",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.12.0",
	"scripts": {
		"dev": "pnpm --filter @tweeq/docs dev",
		"dev:demo": "pnpm --filter @tweeq/docs dev",
		"build": "pnpm build:packages && pnpm build:apps && pnpm build:docs:vue",
		"build:packages": "pnpm -r --filter './packages/**' --if-present build",
		"build:apps": "pnpm -r --filter './apps/**' --if-present build",
		"build:demo": "pnpm --filter @tweeq/docs build",
		"build:demo:vue": "pnpm --filter @tweeq/playground-vue build",
		"build:docs:vue": "vuepress build docs --dest apps/docs/dist/vue",
		"dev:docs:vue": "vuepress dev docs --port 5177",
		"e2e": "playwright test",
		"lint": "eslint packages apps e2e",
		"test": "pnpm -r --if-present test",
		"test:ssr": "node scripts/test-ssr-imports.mjs",
		"docs:check": "node scripts/check-doc-links.mjs && node scripts/check-doc-snippets.mjs",
		"baseline:record": "node scripts/measure-release-baseline.mjs",
		"check:release": "node scripts/check-release-policy.mjs",
		"check:boundaries": "node scripts/check-boundaries.mjs && node scripts/check-consumer-setup.mjs && node scripts/check-react-playground-coverage.mjs && node scripts/check-vue-playground-coverage.mjs",
		"test:packed": "node scripts/test-packed.mjs"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@eslint/js": "^9.21.0",
		"@playwright/test": "^1.61.1",
		"@tweeq/core": "workspace:*",
		"@tweeq/vue": "workspace:*",
		"@vuepress/bundler-vite": "2.0.0-rc.20",
		"@vuepress/client": "2.0.0-rc.20",
		"@vuepress/theme-default": "2.0.0-rc.80",
		"@vueuse/core": "^11.0.3",
		"case": "^1.6.3",
		"chroma-js": "^3.1.1",
		"eslint": "^9.21.0",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"eslint-plugin-unused-imports": "^4.1.4",
		"globals": "^17.7.0",
		"linearly": "catalog:",
		"lodash-es": "catalog:",
		"typescript": "^5.5.3",
		"typescript-eslint": "^8.25.0",
		"vite-plugin-glsl": "catalog:",
		"vue": "catalog:",
		"vuepress": "2.0.0-rc.20"
	}
}
