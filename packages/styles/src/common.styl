font-numeric()
	font-family var(--tq-font-numeric)
	font-variant-numeric tabular-nums

pane-style()
	border 1px solid var(--tq-color-border)
	background var(--tq-color-surface)
	backdrop-filter blur(var(--tq-popup-blur))

popup-style()
	pane-style()
	padding var(--tq-popup-padding)
	border-radius var(--tq-radius-popup)
	box-shadow 0 0 20px 0px var(--tq-color-shadow)
	color var(--tq-color-text)

button-focus-style()
	position relative

	&:before
		content ''
		position absolute
		inset -3px
		border 1px solid var(--tq-color-accent)
		border-radius calc(var(--tq-radius-input) + 2px)

// Focus ring for accent-fillable buttons (Button / ButtonToggle / Checkbox).
// No offset; follows the corner radius (incl. corners squared by
// use-input-position() in a group). Reads --focus-ring so a control can flip it:
// the default is an accent ring just OUTSIDE (reads against a plain bg), but an
// accent-filled control overrides it to an inset on-accent ring drawn just
// INSIDE. An outside ring sits on the page bg, where on-accent is invisible
// (light mode) and an accent ring would merge into the fill.
fill-focus-style()
	box-shadow var(--focus-ring, 0 0 0 1px var(--tq-color-accent))

hover-transition(prop = all)
	values = ()

	for p in arguments
		push(
			values,
			p + ' var(--tq-hover-transition-duration) cubic-bezier(0.4, 0, 0.2, 1)'
		)

	transition unquote(join(',', values))

active-transition(prop = all)
	values = ()

	for p in arguments
		push(
			values,
			p + ' var(--tq-active-transition-duration) cubic-bezier(0.4, 0, 0.2, 1)'
		)

	transition unquote(join(',', values))

use-input-font()
	&[font=numeric]
		font-numeric()

	&[font=monospace]
		font-family var(--tq-font-code)

use-input-align()
	&[align=left]
		text-align left

	&[align=center]
		text-align center

	&[align=right]
		text-align right

use-input-position()
	&[inline-position=middle], &[block-position=middle]
		border-radius 0

	&[inline-position=start]
		border-top-right-radius 0
		border-bottom-right-radius 0

	&[inline-position=end]
		border-top-left-radius 0
		border-bottom-left-radius 0

	&[block-position=start]
		border-bottom-right-radius 0
		border-bottom-left-radius 0

	&[block-position=end]
		border-top-left-radius 0
		border-top-right-radius 0

use-input-theme()
	&[theme=minimal]
		background transparent

		&:hover
			box-shadow 0 0 0 1px var(--tq-color-border)

		&:focus-within
			box-shadow 0 0 0 1px var(--tq-color-accent)

input-overlay()
	position fixed
	inset 0
	z-index 1000
	pointer-events none

	svg
		position absolute
		inset 0
		width 100vw
		height 100vh
		stroke-linecap round
		stroke-linejoin round

	.thin, .bold, .extra-bold
		fill none
		stroke var(--tq-color-accent)

	.gray
		stroke var(--tq-color-border)

	.thin
		stroke-width 1

	.bold
		stroke-width 2

	.extra-bold
		stroke-width 4

	.label
		font-size 1em
		font-numeric()
		fill var(--tq-color-accent)

set-alpha(name, opacity)
	'color-mix(in srgb, var(%s) %d%, transparent)' % (name opacity * 100)

// Registered custom props + keyframes backing scroll-fade-mask(). Declared once
// globally (called from the Viewport's non-scoped style) so the keyframe names
// stay stable and the <length> props can interpolate smoothly.
scroll-fade-globals()
	@property --tq-scroll-fade-top
		syntax '<length>'
		inherits false
		initial-value 0

	@property --tq-scroll-fade-bottom
		syntax '<length>'
		inherits false
		initial-value 0

	@keyframes tq-scroll-fade-top
		from
			--tq-scroll-fade-top 0
		to
			--tq-scroll-fade-top var(--tq-scroll-fade-size)

	@keyframes tq-scroll-fade-bottom
		from
			--tq-scroll-fade-bottom var(--tq-scroll-fade-size)
		to
			--tq-scroll-fade-bottom 0

// Fade the overflowing edge(s) of a scroll container with a mask, revealed by a
// scroll-driven animation: the top fade grows in once you've scrolled down past
// `size`, the bottom fade is present until you reach the end. A non-scrolling
// element keeps the props at their 0 initial value (inactive timeline), so no
// fade shows. Pair with scroll-fade-globals(). Longhands only, so we never reset
// animation-duration/-timeline via the shorthand.
scroll-fade-mask(size = calc(var(--tq-input-height) / 2))
	--tq-scroll-fade-size size
	mask-image unquote('linear-gradient(to bottom, transparent, #000 var(--tq-scroll-fade-top)), linear-gradient(to top, transparent, #000 var(--tq-scroll-fade-bottom))')
	mask-composite intersect
	animation-name tq-scroll-fade-top, tq-scroll-fade-bottom
	animation-fill-mode both
	animation-timing-function linear
	animation-timeline scroll(self)
	animation-range unquote('0 var(--tq-scroll-fade-size), calc(100% - var(--tq-scroll-fade-size)) 100%')

reset-viewport(selector)
	@layer tweeq
		{selector}
			line-height 1
			margin 0
			padding 0
			border 0
			vertical-align baseline
			font inherit
			font-family var(--tq-font-ui)
			font-size var(--tq-rem)
			user-select none
			color var(--tq-color-text)

			*, *:before, *:after
				content unset
				margin 0
				padding 0
				border 0
				vertical-align baseline
				color inherit
				font inherit
				font-size inherit
				box-sizing border-box
				font-weight inherit
				font-style normal
				text-align inherit
				list-style none
				outline none
				cursor inherit
				background transparent

			::selection
				background var(--tq-color-accent)
				color var(--tq-color-on-accent)

			::-webkit-scrollbar
				width var(--tq-scrollbar-width)
				height var(--tq-scrollbar-width)
				background transparent

			::-webkit-scrollbar-thumb
				border-radius 9999px
				background 'color-mix(in srgb, var(--tq-color-text) 20%, transparent)' % ''
