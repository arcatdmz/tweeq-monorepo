	stroke currentColor
	stroke-linecap butt
	stroke-linejoin miter
	stroke-width 2

	&[data-tq-mode='inline']
		display inline-block
		width 1em
		height 1em
		vertical-align middle

	&[data-tq-mode='block']
		display block

	&[data-tq-non-stroke-scaling] *
