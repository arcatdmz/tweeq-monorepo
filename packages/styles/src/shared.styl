// Renderer-neutral component rules. Components opt in through stable
// data-tq-component/data-tq-part attributes; renderer class names are not used.

[data-tq-component='input-button-toggle']
	border-radius var(--tq-radius-input)
	background var(--tq-color-input)
	color var(--tq-color-text)
	height var(--tq-input-height)
	min-width var(--tq-input-height)
	display flex
	align-items center
	justify-content center
	hover-transition(background, color)
	gap var(--tq-gap-related)
	use-input-position()

	&:focus-visible
		fill-focus-style()

	&:hover
		background var(--tq-color-input-hover)

	&[aria-pressed='true']
		background var(--tq-color-accent)
		color var(--tq-color-on-accent)
		--focus-ring inset 0 0 0 1px var(--tq-color-input), 0 0 0 1px var(--tq-color-accent)

		&:hover
			background var(--tq-color-accent-hover)

	&:has([data-tq-part='label'])
		padding 0 .7em

	&:has([data-tq-part='icon']):has([data-tq-part='label'])
		padding-left .5em

	[data-tq-part='icon']
		display block
		width calc(var(--tq-input-height) - 4px)
		height calc(var(--tq-input-height) - 4px)

	[data-tq-part='label']
		line-height var(--tq-input-height)

[data-tq-component='input-button']
	position relative
	height var(--tq-input-height)
	min-width var(--tq-input-height)
	border-radius var(--tq-radius-input)
	background var(--tq-color-accent)
	color var(--tq-color-on-accent)
	display flex
	align-items center
	justify-content center
	hover-transition(background, color)
	gap var(--tq-gap-related)
	--bg var(--tq-color-accent)
	--bg-blink var(--tq-color-accent-hover)
	--focus-ring inset 0 0 0 1px var(--tq-color-input), 0 0 0 1px var(--tq-color-accent)
	use-input-position()

	&:focus-visible
		fill-focus-style()

	&:not(:disabled):hover
		background var(--tq-color-accent-hover)

	&:disabled
		opacity .4
		cursor not-allowed
		animation none

	&:has([data-tq-part='label'])
		padding-inline .75em

	&:has([data-tq-part='label']):has([data-tq-part='icon'])
		padding-left .5em

	&:has([data-tq-part='chevron'])
		padding-right .6em

	&[data-narrow='true']
		min-width 0
		padding-inline 1px

	&[data-subtle='true']
		background var(--tq-color-neutral)
		--bg var(--tq-color-neutral)
		--bg-blink var(--tq-color-neutral-hover)
		--focus-ring 0 0 0 1px var(--tq-color-accent)

		&:not(:hover)
			color var(--tq-color-text)

		&:not(:disabled):hover
			background var(--tq-color-accent-hover)

	&[data-blink='true']
		animation tq-input-button-blink .5s infinite alternate

	&[data-flashing='true']
		position relative
		z-index 1
		animation tq-input-button-flash .6s ease-in-out 2

	[data-tq-part='icon']
		display block
		flex-shrink 0

	[data-tq-part='chevron']
		flex none
		display grid
		place-items center
		width calc(var(--tq-icon-size) * .5)
		margin-left auto
		opacity .6

	[data-tq-part='label']
		line-height var(--tq-input-height)
		min-width 0
		overflow hidden
		white-space nowrap
		text-overflow ellipsis

@keyframes tq-input-button-blink
	0%
		background var(--bg)
	100%
		background var(--bg-blink)

@keyframes tq-input-button-flash
	0%, 100%
		box-shadow 0 0 0 0 transparent
		transform scale(1)
	50%
		box-shadow 0 0 0 2px var(--tq-color-accent), 0 0 10px 1px var(--tq-color-accent)
		transform scale(1.06)

[data-tq-component='input-checkbox']
	display flex
	align-items center
	gap 1em

	&[data-disabled='true']
		cursor not-allowed

		[data-tq-part='track']
			pointer-events none
			background transparent
			box-shadow inset 0 0 0 1px var(--tq-color-border)

		[data-tq-part='track']:has(:checked)
			background var(--tq-color-text-subtle)

		[data-tq-part='label']
			pointer-events none
			color var(--tq-color-text-mute)

	[data-tq-part='track']
		position relative
		background var(--tq-color-input)
		border-radius var(--tq-radius-input)
		width var(--tq-input-height)
		active-transition(background)
		use-input-position()

		&:has([data-tq-part='input']:focus-visible),
		&[data-subfocus='true']
			fill-focus-style()

		&:hover
			background var(--tq-color-input-hover)

		&:has(:checked)
			background var(--tq-color-accent)
			--focus-ring inset 0 0 0 1px var(--tq-color-input), 0 0 0 1px var(--tq-color-accent)

			&:hover
				background var(--tq-color-accent-hover)

	[data-tq-part='input']
		display block
		width var(--tq-input-height)
		height var(--tq-input-height)
		margin 0 !important
		opacity 0
		pointer-events none

	[data-tq-part='mark']
		position absolute
		top calc((var(--tq-input-height) - var(--tq-icon-size)) / 2)
		left calc((var(--tq-input-height) - var(--tq-icon-size)) / 2)
		color set-alpha(--tq-color-text-subtle, .3)
		pointer-events none

	[data-tq-part='input']:checked + [data-tq-part='mark']
		color var(--tq-color-background)

[data-tq-component='input-switch']
	display flex
	align-items center
	gap 1em

	[data-tq-part='track']
		position relative
		width calc(var(--tq-input-height) * 2)
		border-radius 9999px
		background-color var(--tq-color-input)
		active-transition(background-color)
		height var(--tq-input-height)
		use-input-position()

		&:hover
			background-color var(--tq-color-input-hover)

		&:has(:checked)
			background-color var(--tq-color-accent)

			&:hover
				background-color var(--tq-color-accent-hover)

		&:has([data-tq-part='input']:focus),
		&[data-subfocus='true']
			&:before
				content ''
				position absolute
				inset -3px
				border 1px solid var(--tq-color-accent)
				border-radius 999px

	[data-tq-part='handle']
		position absolute
		top 4px
		left 4px
		width calc(var(--tq-input-height) - 8px)
		height calc(var(--tq-input-height) - 8px)
		border-radius 9999px
		background-color var(--tq-color-text-subtle)
		active-transition(left, width, background-color)
		pointer-events none

		&[data-tweaking='true']
			width calc(var(--tq-input-height) - 4px)

	[data-tq-part='input']:checked + [data-tq-part='handle']
		left calc(100% - var(--tq-input-height) + 4px)
		background-color var(--tq-color-background)

		&[data-tweaking='true']
			left calc(100% - var(--tq-input-height))

	[data-tq-part='input']
		position absolute
		opacity 0
		pointer-events none

		&:focus
			pointer-events auto

[data-tq-component='icon-indicator']
	--size var(--tq-input-height)
	height var(--size)
	width var(--size)
	display flex
	align-items center
	justify-content center
	hover-transition(color)
	border-radius 9999px
	color var(--tq-color-text)

	&[data-inline='true']
		--size var(--tq-icon-size)

	&[aria-pressed='false']
		color var(--tq-color-text-mute)

	&[aria-pressed='true']
		color var(--tq-color-accent)

	[data-tq-part='icon']
		display block
		height calc(var(--size) - 2px)
		width calc(var(--size) - 2px)

[data-tq-component='input-shuffle']
	display block
	padding 0
	width var(--tq-input-height)
	height var(--tq-input-height)
	border-radius var(--tq-radius-input)
	background-size 100% 100%
	color var(--tq-color-accent)
	text-align center
	cursor pointer
	hover-transition(background, color)

	&:focus-visible
		background var(--tq-color-accent-hover)

	&:not(:disabled):hover
		background var(--tq-color-accent)
		color var(--tq-color-on-accent)

	&:disabled
		opacity .4
		cursor not-allowed

	[data-tq-part='icon']
		width var(--tq-input-height)
		height var(--tq-input-height)
		transition transform .3s cubic-bezier(.19, 1.6, .42, 1)

[data-tq-component='color-icon']
	aspect-ratio 1
	background currentColor

[data-tq-component='glsl-canvas']
	display block
	pointer-events none

[data-tq-component='input-angle']
	display flex
	gap var(--tq-gap-control)

[data-tq-component='parameter-grid']
	display grid
	grid-template-columns minmax(60px, max-content) minmax(0, 1fr)
	gap var(--tq-gap-control)
	padding-left 3px
	align-items start

[data-tq-component='input-group']
	display flex
	flex-grow 1
	gap var(--tq-gap-group)

	&[data-direction='vertical']
		flex-direction column

[data-tq-component='markdown']
	display block

[data-tq-component='input-group'][data-tq-variant='input-position']
	gap 3px

[data-tq-component='bind-icon']
	display flex
	align-items center
	gap var(--tq-gap-group)

	[data-tq-part='icon']
		width 1em
		height 1em

[data-tq-component='tweak-overlay']
	position fixed
	inset 0
	width 100vw
	height 100vh
	margin 0
	padding 0
	border 0
	background transparent
	overflow visible
	pointer-events none

[data-tq-component='input-number-scales']
	background-image linear-gradient(to right, var(--tq-color-border-subtle) 1px, transparent 1px)
	position absolute
	inset 0
	mask linear-gradient(to right, transparent 1px, black 1px, transparent calc(100% - 1px), black calc(100% - 1px))
	pointer-events none

// Panels stack in one grid cell so the parent sizes to the tallest tab and
// does not jump when switching. Opacity also prevents Monaco descendants from
// overriding inherited visibility while keeping inactive panels laid out.
[data-tq-component='tab']
	height 100%

	&:not([data-tq-active])
		opacity 0
		pointer-events none

[data-tq-component='parameter-heading']
	display flex
	height var(--tq-input-height)
	line-height var(--tq-input-height)
	grid-column 1 / 3

	[data-tq-part='heading']
		font-family var(--tq-font-heading)
		font-size 14px
		font-weight bold
		flex-grow 1
		white-space nowrap

[data-tq-component='input-code']
	position relative
	border-radius var(--tq-radius-input)
	overflow hidden
	min-height calc(var(--tq-input-height) * 10)
	// Monaco scrolls long lines itself; keep constrained hosts shrinkable.
	min-width 0
	background var(--tq-color-input)

	[data-tq-part='editor']
		position absolute !important
		inset calc(var(--tq-input-height) * .25)
		width auto !important
		height auto !important

[data-tq-component='monaco-editor']
	background transparent !important
	width 100%
	height 100%

	.monaco-editor
		--vscode-editor-background transparent !important

[data-tq-component='icon']
	width var(--tq-icon-size)
	height var(--tq-icon-size)

	&[data-tq-variant='char']
		line-height 100%
		font-size 1.2em
		text-align center
		display flex
		align-items center
		justify-content center

[data-tq-component='svg-icon']
	fill none
	stroke currentColor
	stroke-linecap butt
	stroke-linejoin miter
	stroke-width 2

	&[data-tq-mode='inline']
		display inline-block
		width 1em
		height 1em
		vertical-align middle

	&[data-tq-mode='block']
		display block

	&[data-tq-non-stroke-scaling] *
		vector-effect non-scaling-stroke

[data-tq-component='ruler']
	position relative
	overflow hidden
	background-image linear-gradient(to right, var(--tq-color-border) 1px, transparent 1px)

	[data-tq-part='content'], [data-tq-part='scale']
		position absolute
		inset 0

	[data-tq-part='scale']
		pointer-events none
		border-left 1px solid var(--tq-color-text-mute)
		font-size 9px
		color var(--tq-color-text-mute)
		text-indent .4em
