[data-tq-component='input-cubic-bezier-picker']
	width 100%
	height 100%

	[data-tq-part='pad']
		width 100%
		height 100%
		overflow visible

		*
			vector-effect non-scaling-stroke

		g
			transform scaleY(-1)
			transform-origin 50% 50%

		path, line, circle
			fill none
			stroke-linecap round

		path, circle
			stroke-width 2
			stroke var(--tq-color-accent)

		line
			stroke-width 1
			stroke var(--tq-color-accent)

		circle
			fill var(--tq-color-background)
			cursor grab
			hover-transition(fill, stroke)

			&:hover
				fill var(--tq-color-accent)
				stroke var(--tq-color-accent)

[data-tq-app]
	--titlebar-area-height env(titlebar-area-height, 38px)
	position fixed
	inset 0
	background var(--tq-color-background)

	[data-tq-part='main']
		position fixed
		inset var(--titlebar-area-height) 0 0

	&[data-tq-embedded]
		position relative
		inset auto
		min-height 10rem

		[data-tq-part='main']
			position absolute

[data-tq-component='popover']
	position fixed
	inset auto
	background transparent
	overflow visible
	transition opacity var(--tq-active-transition-duration) ease-out

@starting-style
	[data-tq-component='popover']:popover-open
		opacity 0

[data-tq-component='popover'][data-tq-exit-transition]
	opacity 0
	transition opacity var(--tq-active-transition-duration) ease-out, display var(--tq-active-transition-duration) allow-discrete, overlay var(--tq-active-transition-duration) allow-discrete

	[data-tq-balloon]
		transform scale(.96)

	&:popover-open
		opacity 1

		[data-tq-balloon]
			transform scale(1)

@starting-style
	[data-tq-component='popover'][data-tq-exit-transition]:popover-open
		opacity 0

		[data-tq-balloon]
			transform scale(.96)

[data-tq-component='input-size']
	position relative

	[data-tq-vector-index]:not([data-tq-vector-index='0']) [data-tq-part='left-icon']
		left calc(var(--tq-input-height) * .3)

	[data-tq-part='ratio']
		position absolute
		top 0
		left 50%
		transform translateX(-50%)
		width var(--tq-input-height)
		height var(--tq-input-height)
		color var(--tq-color-text-subtle)
		z-index 1
		padding 0
		border 0
		background transparent
		box-sizing border-box

		&:disabled
			pointer-events none
			color var(--tq-color-text-mute)

		&:not(:disabled):hover
			color 'color-mix(in srgb, var(--tq-color-text-mute), transparent 50%)' % ''

		&[aria-pressed='true']
			color var(--tq-color-accent)

			&:not(:disabled):hover
				color var(--tq-color-accent-hover)

	[data-tq-part='ratio-icon']
		width 100%
		height 100%
		transform scale(.8)
