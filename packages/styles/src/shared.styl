	position absolute
	inset 0
	mask linear-gradient(to right, transparent 1px, black 1px, transparent calc(100% - 1px), black calc(100% - 1px))
	pointer-events none

// Panels stack in one grid cell so the parent sizes to the tallest tab and
// does not jump when switching. Opacity also prevents Monaco descendants from
// overriding inherited visibility while keeping inactive panels laid out.
[data-tq-component='tab']
	height 100%

	&:not([data-tq-active])
		opacity 0
		pointer-events none

[data-tq-component='parameter-heading']
