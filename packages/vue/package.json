{
	"name": "@tweeq/vue",
	"version": "0.0.0",
	"private": true,
	"description": "Vue 3 renderer for Tweeq (legacy upstream implementation, Stage V1)",
	"type": "module",
	"types": "./dist/index.d.ts",
	"main": "./dist/index.umd.js",
	"module": "./dist/index.es.js",
	"style": "./dist/style.css",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.es.js",
			"require": "./dist/index.umd.js"
		},
		"./style.css": "./dist/style.css"
	},
	"sideEffects": [
		"**/*.css"
	],
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rm -rf dist && vite build",
		"test": "vitest run --passWithNoTests"
	},
	"peerDependencies": {
		"vue": "^3.0.0"
	},
	"devDependencies": {
		"@types/chroma-js": "^2.4.3",
		"@types/lodash-es": "catalog:",
		"@types/markdown-it": "^14.1.2",
		"@vitejs/plugin-vue": "catalog:",
		"stylus": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vite-plugin-dts": "catalog:",
		"vite-plugin-glsl": "catalog:",
		"vitest": "catalog:",
		"vue": "catalog:",
		"vue-tsc": "^2.1.10"
	},
	"dependencies": {
		"@baku89/pave": "^0.6.2",
		"@iconify/vue": "^4.1.2",
		"@radix-ui/colors": "^3.0.0",
		"@tweeq/core": "workspace:^",
		"@tweeq/dom": "workspace:^",
		"@tweeq/styles": "workspace:^",
		"@vueuse/core": "^11.0.3",
		"bezier-easing": "^2.1.0",
		"bndr-js": "catalog:",
		"case": "^1.6.3",
		"chroma-js": "^3.1.1",
		"colorjs.io": "^0.5.0",
		"fast-fuzzy": "^1.12.0",
		"line-intersect": "^3.0.0",
		"linearly": "catalog:",
		"lodash-es": "catalog:",
		"markdown-it": "^14.0.0",
		"markdown-it-anchor": "^9.0.1",
		"markdown-it-deflist": "^3.0.0",
		"markdown-it-footnote": "^4.0.0",
		"markdown-it-toc-done-right": "^4.2.0",
		"monaco-editor": "^0.54.0",
		"monaco-editor-vue3": "^1.0.4",
		"p-queue": "^8.0.1",
		"pinia": "^3.0.1",
		"regl": "^2.1.1",
		"validate-color": "^2.2.4"
	}
}
