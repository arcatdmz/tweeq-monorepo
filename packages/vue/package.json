{
	"name": "@tweeq/vue",
	"version": "0.0.0",
	"private": true,
	"description": "Vue 3 renderer for Tweeq",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/arcatdmz/tweeq-monorepo.git",
		"directory": "packages/vue"
	},
	"homepage": "https://tweeq.junkato.jp/",
	"bugs": "https://github.com/arcatdmz/tweeq-monorepo/issues",
	"type": "module",
	"types": "./dist/index.d.ts",
	"main": "./dist/index.cjs",
	"module": "./dist/index.es.js",
	"style": "./dist/style.css",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.es.js",
			"require": "./dist/index.cjs"
		},
		"./style.css": "./dist/style.css"
	},
	"sideEffects": [
		"**/*.css"
	],
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rm -rf dist && vite build && node ../../scripts/copy-style-artifact.mjs vue",
		"test": "vitest run --passWithNoTests"
	},
	"peerDependencies": {
		"vue": "^3.0.0"
	},
	"devDependencies": {
		"@tweeq/test-contracts": "workspace:*",
		"@tweeq/styles": "workspace:^",
		"@types/chroma-js": "^2.4.3",
		"@types/lodash-es": "catalog:",
		"@vitejs/plugin-vue": "catalog:",
		"jsdom": "^26.1.0",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vite-plugin-dts": "catalog:",
		"vite-plugin-glsl": "catalog:",
		"vitest": "catalog:",
		"vue": "catalog:",
		"vue-tsc": "^2.1.10"
	},
	"dependencies": {
		"@iconify/vue": "^4.1.2",
		"@tweeq/core": "workspace:^",
		"@tweeq/dom": "workspace:^",
		"@vueuse/core": "^11.0.3",
		"bndr-js": "catalog:",
		"case": "^1.6.3",
		"chroma-js": "^3.1.1",
		"colorjs.io": "^0.5.0",
		"fast-fuzzy": "^1.12.0",
		"linearly": "catalog:",
		"lodash-es": "catalog:",
		"monaco-editor": "^0.54.0",
		"monaco-editor-vue3": "^1.0.4"
	}
}
