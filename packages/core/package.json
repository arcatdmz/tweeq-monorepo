{
	"name": "@tweeq/core",
	"version": "0.0.0",
	"private": true,
	"description": "Framework-neutral value semantics, validation, formatting, and state transitions for Tweeq",
	"type": "module",
	"types": "./dist/index.d.ts",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./validator": {
			"types": "./dist/validator.d.ts",
			"import": "./dist/validator.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.build.json",
		"test": "vitest run"
	},
	"devDependencies": {
		"@types/chroma-js": "^2.4.3",
		"@types/lodash-es": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"dependencies": {
		"@radix-ui/colors": "^3.0.0",
		"bezier-easing": "^2.1.0",
		"bndr-js": "catalog:",
		"case": "^1.6.3",
		"chroma-js": "^3.1.1",
		"colorjs.io": "^0.5.0",
		"line-intersect": "^3.0.0",
		"linearly": "catalog:",
		"lodash-es": "catalog:",
		"validate-color": "^2.2.4"
	}
}
